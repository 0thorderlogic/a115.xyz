---
import { CALENDAR_IDS } from "../../lib/calendar/constants";
---

<div class="flex items-center justify-between mb-4">
  <button
    id={CALENDAR_IDS.prevMonthButton}
    class="font-mono flex items-center gap-1.5 px-3 py-1 bg-gruv-bg0-s rounded text-gruv-fg hover:bg-gruv-gray hover:text-gruv-bg hover:cursor-pointer transition-colors"
    aria-label="Previous month"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="2.5"
      stroke="currentColor"
      class="w-4 h-4"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"
      />
    </svg>
  </button>
  <h2
    id={CALENDAR_IDS.monthHeader}
    class="title-2 m-0 text-gruv-yellow-light"
  ></h2>
  <button
    id={CALENDAR_IDS.nextMonthButton}
    class="font-mono flex items-center gap-1.5 px-3 py-1 bg-gruv-bg0-s rounded text-gruv-fg hover:bg-gruv-gray hover:text-gruv-bg hover:cursor-pointer transition-colors"
    aria-label="Next month"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="2.5"
      stroke="currentColor"
      class="w-4 h-4"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
      />
    </svg>
  </button>
</div>
