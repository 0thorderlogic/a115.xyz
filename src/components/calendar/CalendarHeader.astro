---
import { CALENDAR_IDS } from "../../lib/calendar/constants";
---

<div class="flex flex-col gap-2 mb-4">
  <div class="flex items-center justify-between">
    <button
      id={CALENDAR_IDS.prevMonthButton}
      class="px-3 py-1 bg-gruv-bg0-s rounded text-gruv-fg hover:bg-gruv-gray hover:text-gruv-bg hover:cursor-pointer transition-colors"
      aria-label="Previous month"
    >
      {"<-"}
    </button>
    <div class="flex items-center gap-3">
      <h2 id={CALENDAR_IDS.monthHeader} class="title-2 m-0 text-gruv-yellow-light"></h2>
      <select
        id={CALENDAR_IDS.timezoneSelect}
        class="bg-gruv-bg0-s text-gruv-fg text-sm rounded px-2 py-1 border border-gruv-gray/30 hover:border-gruv-gray cursor-pointer transition-colors focus:outline-none focus:border-gruv-yellow"
        aria-label="Select timezone"
      >
        <option value="Asia/Kolkata">IST</option>
        <option value="America/New_York">ET</option>
        <option value="America/Chicago">CT</option>
        <option value="America/Los_Angeles">PT</option>
      </select>
    </div>
    <button
      id={CALENDAR_IDS.nextMonthButton}
      class="px-3 py-1 bg-gruv-bg0-s rounded text-gruv-fg hover:bg-gruv-gray hover:text-gruv-bg hover:cursor-pointer transition-colors"
      aria-label="Next month"
    >
      {"->"}
    </button>
  </div>
</div>
