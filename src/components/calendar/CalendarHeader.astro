---
import { CALENDAR_IDS } from "../../lib/calendar/constants";
---

<div class="flex flex-col gap-2 mb-4">
  <div class="flex items-center justify-between">
    <button
      id={CALENDAR_IDS.prevMonthButton}
      class="px-3 py-1 bg-slate-900 rounded text-slate-200 hover:bg-slate-400 hover:text-slate-950 hover:cursor-pointer transition-colors"
      aria-label="Previous month"
    >
      {"<-"}
    </button>
    <div class="flex items-center gap-3">
      <h2 id={CALENDAR_IDS.monthHeader} class="title-2 m-0"></h2>
      <select
        id={CALENDAR_IDS.timezoneSelect}
        class="bg-slate-900 text-slate-200 text-sm rounded px-2 py-1 border border-slate-400/30 hover:border-slate-400 cursor-pointer transition-colors focus:outline-none focus:border-orange-500"
        aria-label="Select timezone"
      >
        <option value="Asia/Kolkata">IST</option>
        <option value="America/New_York">ET</option>
        <option value="America/Chicago">CT</option>
        <option value="America/Los_Angeles">PT</option>
      </select>
    </div>
    <button
      id={CALENDAR_IDS.nextMonthButton}
      class="px-3 py-1 bg-slate-900 rounded text-slate-200 hover:bg-slate-400 hover:text-slate-950 hover:cursor-pointer transition-colors"
      aria-label="Next month"
    >
      {"->"}
    </button>
  </div>
</div>
