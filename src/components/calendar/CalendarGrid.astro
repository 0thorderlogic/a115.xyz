---
import { CALENDAR_IDS, CALENDAR_WEEKDAYS } from "../../lib/calendar/constants";
---

<div class="grid grid-cols-7 gap-1 md:gap-2 mb-2">
  {
    CALENDAR_WEEKDAYS.map((day) => (
      <div class="text-center font-bold text-gruv-aqua p-2 bg-gruv-bg0-s rounded text-sm md:text-base">
        {day}
      </div>
    ))
  }
</div>
<div id={CALENDAR_IDS.grid} class="grid grid-cols-7 gap-1 md:gap-2">
  {/* Days are injected by calendar script */}
</div>
