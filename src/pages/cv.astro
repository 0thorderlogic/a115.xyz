---
import Layout from "../layout/Layout.astro";
---

<Layout title="Curriculum Vitae">
  <section class="w-full space-y-12 mb-12">
    <div>
      <h2 class="title-2">Experience</h2>
      <div class="space-y-8 mt-4">
        <div>
          <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline mb-1">
            <h3 class="text-xl font-bold text-slate-200 m-0">Junior Research Engineer</h3>
            <span class="text-sm text-slate-400 mt-1 sm:mt-0 pt-0.5">April 2026 - Present</span>
          </div>
          <div class="mb-3">
            <a
              href="https://neuroailabs.in/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-orange-500 hover:text-orange-400 font-medium">NeuroAI Fusion Labs</a
            >
            <span class="text-slate-500 mx-2">|</span>
            <span class="text-slate-400 text-sm">Kolkata, WB, India</span>
          </div>
        </div>

        <div>
          <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline mb-1">
            <h3 class="text-xl font-bold text-slate-200 m-0">Trainee Intern</h3>
            <span class="text-sm text-slate-400 mt-1 sm:mt-0 pt-0.5"
              >September 2025 - March 2026</span
            >
          </div>
          <div class="mb-3">
            <a
              href="https://www.isical.ac.in"
              target="_blank"
              rel="noopener noreferrer"
              class="text-orange-500 hover:text-orange-400 font-medium"
              >Technology Innovation Hub, Indian Statistical Institute, Calcutta</a
            >
            <span class="text-slate-500 mx-2">|</span>
            <span class="text-slate-400 text-sm">Kolkata, WB, India</span>
          </div>
        </div>
      </div>
    </div>

    <div>
      <h2 class="title-2">Projects</h2>
      <div class="space-y-8 mt-4">
        <div>
          <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline mb-1">
            <h3 class="text-xl font-bold text-slate-200 m-0">
              Sense (Web-Page to Braille converter)
            </h3>
          </div>
          <div class="mb-3">
            <a
              href="https://0thorderlogic.github.io/sense"
              target="_blank"
              rel="noopener noreferrer"
              class="text-orange-500 hover:text-orange-400 font-medium break-all"
              >https://0thorderlogic.github.io/sense</a
            >
          </div>
          <ul class="list-outside text-slate-300 space-y-2 ml-4 marker:text-slate-500">
            <li>
              Provides accessibility for an overlooked community. Transforms website text into
              tactile Braille in real time for visually and auditorily impaired using Python,
              Arduino, and servo motors.
            </li>
          </ul>
          <div class="flex flex-wrap gap-2 mt-3 ml-4">
            <span class="text-xs text-slate-500 font-mono"
              >Arduino / C / Hardware / Web Scraping</span
            >
          </div>
        </div>
      </div>
    </div>

    <div>
      <h2 class="title-2">Education</h2>
      <div class="space-y-6 mt-4">
        <div>
          <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline mb-1">
            <h3 class="text-xl font-bold text-slate-200 m-0">
              Bachelor of Technology in Computer Science and Engineering
            </h3>
            <span class="text-sm text-slate-400 mt-1 sm:mt-0 pt-0.5">July 2021 - June 2025</span>
          </div>
          <div class="mb-3">
            <a
              href="https://www.makautwb.ac.in/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-orange-500 hover:text-orange-400 font-medium"
              >Maulana Abul Kalam Azad University of Technology, West Bengal</a
            >
            <span class="text-slate-500 mx-2">|</span>
            <span class="text-slate-400 text-sm">Kolkata, WB, India</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
