---
import { getCollection } from "astro:content";
import Layout from "../../layout/JournalPost.astro";

export async function getStaticPaths() {
  const journalEntries = await getCollection("journal");
  return journalEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const postDescription = entry.data.description ?? entry.data.title;

const formattedDate = entry.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title={entry.data.title} description={postDescription} ogType="article">
  {entry.data.description && <h2 class="title-2">{entry.data.description}</h2>}
  <article class="max-w-3xl prose-custom">
    <header>
      <p class="text-sm m-0">
        <time datetime={entry.data.date.toISOString()}>{formattedDate}</time>
      </p>
    </header>

    <div class="prose prose-invert max-w-none">
      <Content />
    </div>
  </article>
</Layout>

<style is:global>
  @reference "../../styles/global.css";
  /* Basic minimal styling for the markdown output to fit Tailwind */
  .prose-custom {
    @apply text-slate-200 leading-relaxed;
  }

  .prose-custom h1,
  .prose-custom h2,
  .prose-custom h3,
  .prose-custom h4 {
    @apply font-bold mt-8 mb-4;
  }

  .prose-custom h1 {
    @apply text-2xl text-orange-500;
  }
  .prose-custom h2 {
    @apply text-xl text-purple-500;
  }
  .prose-custom h3 {
    @apply text-lg text-cyan-500;
  }

  .prose-custom p {
    @apply mb-4;
  }

  .prose-custom ul {
    @apply list-disc list-inside mb-4 pl-4;
  }

  .prose-custom ol {
    @apply list-decimal list-inside mb-4 pl-4;
  }

  .prose-custom pre {
    @apply bg-slate-900 p-4 rounded-md overflow-x-auto mb-4 border border-slate-300/20;
  }

  .prose-custom code {
    @apply font-mono text-sm bg-slate-900 px-1.5 py-0.5 rounded text-teal-400;
  }

  .prose-custom pre code {
    @apply bg-transparent p-0 text-inherit;
  }

  .prose-custom blockquote {
    @apply border-l-4 border-slate-300 bg-slate-900 py-2 pl-4 pr-2 mb-4 italic text-slate-300;
  }

  .prose-custom blockquote p:last-child {
    @apply mb-0;
  }

  .prose-custom p:has(img) {
    @apply flex flex-col items-center my-12 text-slate-400 italic text-sm text-center gap-3;
  }
</style>
