---
import Layout from "../layout/Layout.astro";
import { getCollection } from "astro:content";

// Fetch all journal entries
const allJournalEntries = await getCollection("journal");

// Sort entries by date (newest first)
const sortedEntries = allJournalEntries.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const groupedByYear = sortedEntries.reduce(
  (acc, post) => {
    const year = post.data.date.getFullYear().toString();
    if (!acc[year]) acc[year] = [];
    acc[year].push(post);
    return acc;
  },
  {} as Record<string, typeof sortedEntries>,
);

const sortedYears = Object.entries(groupedByYear).sort(
  ([yearA], [yearB]) => Number(yearB) - Number(yearA),
);
---

<Layout title="Journal">
  <section class="w-full space-y-8">
    <div class="flex items-center justify-start">
      <a
        href="/rss.xml"
        class="title-2 text-orange-500! hover:text-slate-300 transition-colors no-underline!"
        target="_blank"
        rel="noopener noreferrer"
      >
        RSS Feed
      </a>
    </div>
    <div class="space-y-4">
      {
        sortedYears.map(([year, posts]) => (
          <details class="group" open>
            <summary class="flex items-center gap-4 cursor-pointer list-none select-none py-2">
              <h2 class="title-2 text-4xl md:text-5xl text-orange-500 m-0">{year}</h2>
              <div class="flex-grow h-px bg-slate-400/20 group-hover:bg-slate-400/40 transition-colors" />
              <div class="text-slate-400/50 group-open:rotate-180 transition-transform duration-200">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  class="w-6 h-6"
                >
                  <path
                    fill-rule="evenodd"
                    d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z"
                    clip-rule="evenodd"
                  />
                </svg>
              </div>
            </summary>

            <div class="space-y-4 pt-4 pb-6 pl-4 sm:pl-8 border-l-2 border-slate-400/20 ml-2 sm:ml-4 mt-2">
              {posts.map((post) => (
                <article class="p-3 sm:p-4 border border-slate-400/20 rounded bg-slate-900 relative hover:border-slate-400/40 transition-colors shadow-sm group/card grid grid-cols-1 sm:grid-cols-[160px_1fr] sm:items-baseline gap-2 sm:gap-4">
                  <div class="absolute -left-[18px] sm:-left-[34px] top-[26px] w-[18px] sm:w-[34px] h-[2px] bg-slate-400/20 hidden sm:block group-hover/card:bg-slate-400/40 transition-colors" />

                  <time
                    datetime={post.data.date.toISOString()}
                    class="text-xs sm:text-sm text-slate-400 shrink-0"
                  >
                    {post.data.date.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                  <a
                    href={`/journal/${post.slug}`}
                    class="no-underline! text-slate-200 hover:text-blue-500 transition-colors"
                  >
                    <h3 class="text-lg font-bold font-sans! m-0 leading-tight group-hover/card:text-blue-500 transition-colors">
                      {post.data.title}
                    </h3>
                    <p class="text-slate-200">{post.data.description}</p>
                  </a>
                </article>
              ))}
            </div>
          </details>
        ))
      }
    </div>
  </section>
</Layout>
