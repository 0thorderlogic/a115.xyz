---
import Layout from "../layout/Layout.astro";
import { getCollection } from "astro:content";

// Fetch all journal entries
const allJournalEntries = await getCollection("journal");

// Sort entries by date (newest first)
const sortedEntries = allJournalEntries.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const groupedByYear = sortedEntries.reduce(
  (acc, post) => {
    const year = post.data.date.getFullYear().toString();
    if (!acc[year]) acc[year] = [];
    acc[year].push(post);
    return acc;
  },
  {} as Record<string, typeof sortedEntries>,
);

const sortedYears = Object.entries(groupedByYear).sort(
  ([yearA], [yearB]) => Number(yearB) - Number(yearA),
);
---

<Layout title="Journal">
  <section class="max-w-4xl space-y-8">
    <div class="flex justify-between items-end">
      <a
        href="/rss.xml"
        class="text-gruv-orange! hover:text-gruv-orange-light flex items-center gap-2 font-mono no-underline!"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"
          ></path><circle cx="5" cy="19" r="1"></circle></svg
        >
        RSS Feed
      </a>
    </div>

    <div class="space-y-10">
      {
        sortedYears.map(([year, posts]) => (
          <div class="space-y-6">
            <h2 class="title-2 text-5xl md:text-6xl text-gruv-yellow m-0">
              {year}
            </h2>
            <div class="space-y-4 pl-2 md:pl-4 border-l-2 border-gruv-gray/20">
              {posts.map((post) => (
                <article class="grid grid-cols-[max-content_1fr] gap-4 items-baseline">
                  <time
                    datetime={post.data.date.toISOString()}
                    class="text-sm text-gruv-gray font-mono"
                  >
                    {post.data.date.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                  <a href={`/journal/${post.slug}`} class="no-underline!">
                    <h3 class="title-2 font-sans! m-0">{post.data.title}</h3>
                  </a>
                </article>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>
</Layout>
