---
import Layout from "../layout/Layout.astro";
import archiveData from "../content/archive.json";

// Extract the type of a single item from the JSON array
type ArchiveItem = (typeof archiveData)[0];

// Sort data descending by date
const sortedData = [...archiveData].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
);

// Group items by year
const groupedByYear = sortedData.reduce(
  (acc, item) => {
    const year = new Date(item.date).getFullYear().toString();
    if (!acc[year]) acc[year] = [];
    acc[year].push(item);
    return acc;
  },
  {} as Record<string, ArchiveItem[]>,
);

// Sort the years themselves descending
const sortedYears = Object.entries(groupedByYear).sort(
  ([yearA], [yearB]) => Number(yearB) - Number(yearA),
);
---

<Layout title="Archive">
  <div class="max-w-5xl space-y-7">
    {
      sortedYears.map(([year, items], index) => (
        <details
          class="group rounded bg-gruv-bg0-s/30 px-3 py-2"
          open={index === 0}
        >
          <summary class="flex cursor-pointer list-none items-center justify-between gap-3 py-1 marker:content-none">
            <div class="flex items-baseline gap-3">
              <h2 class="title-2 text-2xl md:text-3xl text-gruv-yellow m-0">
                {year}
              </h2>
              <span class="text-xs md:text-sm font-mono text-gruv-gray">
                {items.length} {items.length === 1 ? "entry" : "entries"}
              </span>
            </div>
            <span class="text-xs font-mono text-gruv-blue group-open:rotate-90 transition-transform">
              ▶
            </span>
          </summary>

          <div class="mt-2 space-y-2 pt-2">
            {items.map((item) => (
              <article class="rounded bg-gruv-bg0-s px-3 py-2.5">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between sm:gap-3">
                  <div class="min-w-0">
                    <div class="flex items-center gap-2">
                      <h3 class="m-0 text-base md:text-lg font-semibold text-gruv-fg">
                        {item.title}
                      </h3>
                      <span class="rounded bg-gruv-bg px-1.5 py-0.5 text-[11px] font-mono text-gruv-gray">
                        PDF
                      </span>
                    </div>
                    <p class="mt-1 mb-0 text-sm leading-snug text-gruv-fg/75">
                      {item.description}
                    </p>
                  </div>
                  <div class="flex items-center justify-between gap-3 sm:justify-end sm:pl-2">
                    <time
                      class="text-xs md:text-sm font-mono text-gruv-gray whitespace-nowrap"
                      datetime={item.date}
                    >
                      {item.date}
                    </time>
                    <a
                      href={item.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1 rounded bg-gruv-blue/15 px-2.5 py-1 text-xs md:text-sm font-mono text-gruv-blue no-underline hover:bg-gruv-blue/25"
                    >
                      Open
                    </a>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </details>
      ))
    }
  </div>
</Layout>
