---
import Layout from "../layout/Layout.astro";
import CalendarGrid from "../components/calendar/CalendarGrid.astro";
import CalendarHeader from "../components/calendar/CalendarHeader.astro";
import CalendarModal from "../components/calendar/CalendarModal.astro";
import { CALENDAR_IDS } from "../lib/calendar/constants";
import { fetchCalendarEvents } from "../lib/calendar/fetchEvents";
import type { CalendarEvent } from "../lib/calendar/types";

const apiKey = import.meta.env.GOOGLE_API_KEY;
const calendarId = import.meta.env.GOOGLE_CALENDAR_ID;

let events: CalendarEvent[] = [];
let error: string | null = null;

if (apiKey && calendarId) {
  try {
    events = await fetchCalendarEvents(apiKey, calendarId);
  } catch (cause) {
    error =
      cause instanceof Error
        ? cause.message
        : "Failed to fetch calendar events.";
  }
} else {
  error =
    "Google Calendar API key or Calendar ID is missing in environment variables.";
}
---

<Layout title="Calendar">
  <section class="space-y-4">
    {
      error ? (
        <p class="text-gruv-red">{error}</p>
      ) : (
        <div id={CALENDAR_IDS.container}>
          <CalendarHeader />
          <CalendarGrid />
        </div>
      )
    }
  </section>

  <CalendarModal />

  {
    !error && (
      <>
        <script
          id="calendar-events-data"
          type="application/json"
          set:html={JSON.stringify(events)}
        ></script>
        <script>
          import { initCalendarFromDom } from "../scripts/calendar";

          initCalendarFromDom("calendar-events-data");
        </script>
      </>
    )
  }
</Layout>

<style is:global>
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }

  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
